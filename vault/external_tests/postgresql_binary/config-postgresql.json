    {
      "policy": {
        "request": [
          {
            "add-superuser-policy": {
              "operation": "update",
              "path": "sys/policies/acl/superuser",
              "data": {
                "policy": "path \"*\" {\n  capabilities = [\"create\", \"update\", \"read\", \"delete\", \"list\", \"scan\", \"sudo\"]\n}"
              }
            }
          }
        ]
      }
    }
  ]
